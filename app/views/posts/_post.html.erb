<div id="<%= dom_id post %>">
  <h2>
    <strong></strong>
    <%= post.title %>
  </h2>

  <p>
    <strong>Body:</strong>
    <%= post.body %>
  </p>

  <p>
    <strong>Email:</strong>
    <%= post.user.email %>
  </p>

  <p>
    <strong>Made By:</strong>
    <%= post.user.user_name %>
  </p>

</div>
